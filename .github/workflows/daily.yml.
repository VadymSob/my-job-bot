
name: Job Monitoring

on:
  schedule:
    - cron: '0 7 * * *' # Це 9:00 за київським часом
  workflow_dispatch: 

jobs:
  run_bot:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v3
      - name: Setup Python
        uses: actions/setup-python@v4
        with:
          python-version: '3.10'
      - name: Install dependencies
        run: pip install requests beautifulsoup4
      - name: Run Script
        env:
          WORK_UA_COOKIE: ${{ secrets.WORK_UA_COOKIE }}
          TELEGRAM_TOKEN: ${{ secrets.TELEGRAM_TOKEN }}
          CHAT_ID: ${{ secrets.CHAT_ID }}
        run: python bot.py
